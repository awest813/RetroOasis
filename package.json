{
    "name": "@emulatorjs/emulatorjs",
    "version": "4.2.4",
    "type": "module",
    "description": "EmulatorJS is a frontend for RetroArch in the web browser.",
    "homepage": "https://emulatorjs.org",
    "license": "GPL-3.0",
    "sideEffects": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/EmulatorJS/EmulatorJS.git"
    },
    "bugs": {
        "url": "https://github.com/EmulatorJS/EmulatorJS/issues"
    },
    "scripts": {
        "start": "http-server",
        "minify": "node minify/minify.js",
        "build": "npm --prefix retrooasis install && npm --prefix retrooasis run build && node scripts/sync-pages-dist.mjs",
        "build:emulatorjs": "node build.js",
        "update": "node update.js",
        "docs": "jsdoc data/src/*.js -d jsdoc",
        "oasis:dev": "npm --prefix retrooasis run dev",
        "oasis:build": "npm --prefix retrooasis run build",
        "oasis:preview": "npm --prefix retrooasis run preview",
        "oasis:manifest": "npm --prefix retrooasis run manifest",
        "oasis:scan": "npm --prefix retrooasis run scan"
    },
    "dependencies": {
        "@node-minify/clean-css": "^10.4.0",
        "@node-minify/core": "^10.4.0",
        "http-server": "^14.1.1",
        "node-7z": "^3.0.0"
    },
    "optionalDependencies": {
        "@emulatorjs/cores": "latest"
    },
    "devDependencies": {
        "@rollup/plugin-terser": "^1.0.0",
        "eslint": "^10.0.2",
        "jsdoc": "^4.0.5",
        "nipplejs": "^0.10.2",
        "node-fetch": "^3.3.2",
        "rollup": "^4.59.0",
        "socket.io": "^4.8.3"
    }
}
